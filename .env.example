# asn-cf-interactive-media — environment variables.
#
# Copy to .env and fill in the secrets for local development:
#
#     cp .env.example .env
#
# Secrets for AUTH0_CLIENT_ID / AUTH0_CLIENT_SECRET are provisioned by
# Tribe ops (Jeremy / Andrew / Nick via #tribe-ops) and shared through
# 1Password. Generate OAUTH2_PROXY_COOKIE_SECRET locally with:
#
#     openssl rand -hex 32
#
# Do not commit .env to git (.env is gitignored).

# ---- Auth0 (Tribe internal-apps standard) ---------------------------------

AUTH0_ISSUER=https://auth.tribe.ai
AUTH0_CLIENT_ID=<from #tribe-ops>
AUTH0_CLIENT_SECRET=<from #tribe-ops>

# tribe-google-workspace is domain-locked to @tribe.ai accounts. Setting
# this here pushes users straight to the Google account chooser instead
# of Auth0's universal login.
AUTH0_CONNECTION=tribe-google-workspace

# ---- oauth2-proxy ---------------------------------------------------------

# 32-byte hex string — used to sign the session cookie. Rotate to log
# everyone out. Generate with: openssl rand -hex 32
OAUTH2_PROXY_COOKIE_SECRET=<run: openssl rand -hex 32>

# Must exactly match the callback URL registered in Auth0 for this client.
# Local dev:  http://localhost:8080/oauth2/callback
# Production: https://asn-cf-interactive-media-production.up.railway.app/oauth2/callback
OAUTH2_PROXY_REDIRECT_URL=http://localhost:8080/oauth2/callback

# ---- Annotation backend ---------------------------------------------------

# Path inside the container; leave alone unless you remount the volume.
CSV_PATH=/data/claims.csv
